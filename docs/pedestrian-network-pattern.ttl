@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <https://w3id.org/itsdata/transport-network/v1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix its-core: <https://w3id.org/itsdata/core/v1/> .
@prefix its-location: <https://w3id.org/itsdata/location/v1/> .
@prefix schema: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .

:PedestrianNetworkPattern
    a owl:Ontology ;
    dcterms:title "ITS Ontology - Transport Network - Pedestrian Network Pattern"@en ;
    skos:definition "This pattern defines pedestrian network concepts, which are derived from ITS Location features and can be presented with multiple geometries."@en ;
    dcterms:creator "Kenneth Vaughn" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-05-05T21:43:49Z"^^xsd:dateTime ;
    dcterms:license "http://creativecommons.org/licenses/by/4.0/" ;
    its-core:draft "true" ;
    owl:imports :TransportNetworkPattern ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <https://w3id.org/itsdata/transport-network/v1/PedestrianNetworkPattern/r0.1> ;
    vann:preferredNamespacePrefix "its-tn" ;
    vann:preferredNamespaceUri "https://w3id.org/itsdata/transport-network/v1/" .

:FootpathNetwork
    a owl:Class ;
    rdfs:subClassOf :TransportNetwork ;
    skos:definition "A transport network for pedestrian paths."@en .

:Footpath
    a owl:Class ;
    rdfs:subClassOf :TravelledWay ;
    skos:definition "A travelled way intended primarily for pedestrians."@en .

:FootpathLane
    a owl:Class ;
    rdfs:subClassOf :TravelledWayLane ;
    skos:definition "A lane or channel along a footpath."@en .

:FootpathLink
    a owl:Class ;
    rdfs:subClassOf :TravelledWayLink ;
    skos:definition "A directed footpath link between nodes."@en .

#################################################################
# Property domain hints for this pattern
#################################################################

:hasStartNode schema:domainIncludes :FootpathLink .
:hasEndNode schema:domainIncludes :FootpathLink .

:FootpathSection
    a owl:Class ;
    rdfs:subClassOf :TravelledWaySection ;
    skos:definition "A contiguous section of a footpath."@en .

:FootpathSegment
    a owl:Class ;
    rdfs:subClassOf :TravelledWaySegment ;
    skos:definition "A homogeneous segment of a footpath."@en .

