BASE <https://w3id.org/itsdata/transport-network/v1/>
PREFIX : <https://w3id.org/itsdata/transport-network/v1/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX its-core: <https://w3id.org/itsdata/core/v1/>
PREFIX its-location: <https://w3id.org/itsdata/location/v1/>
PREFIX its-sh: <https://w3id.org/itsdata/shacl/v1/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

:RailNetworkSHACL
    a owl:Ontology ;
    dcterms:title "SHACL rules for ITS Rail Network pattern"@en ;
    skos:definition "SHACL node shapes for rail-network classes, which inherit constraints from the ITS Location ontology."@en ;
    its-core:draft "true" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-05-05T21:43:49Z"^^xsd:dateTime ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <RailNetworkSHACL/r0.1> ;
    owl:imports its-location:LocationCoreSHACL ;
    owl:imports its-location:LinearSHACL ;
    owl:imports its-location:AreaSHACL ;
     owl:imports :TransportNetworkSHACL .

:RailNetworkShape
    a sh:NodeShape ;
    sh:targetClass :RailNetwork ;
    sh:and ( its-location:LocationGroupShape ) .

:RailCorridorShape
    a sh:NodeShape ;
    sh:targetClass :RailCorridor ;
    sh:and ( its-location:AreaFeatureShape ) .

:RailSectionShape
    a sh:NodeShape ;
    sh:targetClass :RailSection ;
    sh:and ( its-location:LinearFeatureShape ) .

:TrackLinkShape
    a sh:NodeShape ;
    sh:targetClass :TrackLink ;
    sh:and ( its-location:LinearFeatureShape ) .

:TrackSegmentShape
    a sh:NodeShape ;
    sh:targetClass :TrackSegment ;
    sh:and ( its-location:LinearFeatureShape ) .

