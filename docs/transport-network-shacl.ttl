BASE <https://w3id.org/itsdata/transport-network/v1/>
PREFIX : <https://w3id.org/itsdata/transport-network/v1/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX its-core: <https://w3id.org/itsdata/core/v1/>
PREFIX its-location: <https://w3id.org/itsdata/location/v1/>
PREFIX its-sh: <https://w3id.org/itsdata/shacl/v1/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

:TransportNetworkSHACL
    a owl:Ontology ;
    dcterms:title "SHACL rules for ITS Transport Network Core"@en ;
    skos:definition "SHACL node shapes for core transport-network classes shared across pattern modules."@en ;
    its-core:draft "true" ;
    dcterms:created "Draft" ;
    dcterms:modified "2026-05-05T21:43:49Z"^^xsd:dateTime ;
    owl:versionInfo "0.0.1" ;
    owl:versionIRI <TransportNetworkSHACL/r0.1> ;
    owl:imports its-location:LocationCoreSHACL ;
    owl:imports its-location:PointSHACL ;
    owl:imports its-location:LinearSHACL ;
    owl:imports its-location:AreaSHACL .

#################################################################
# Core transport node shapes
#################################################################

:TransportNetworkThingShape
    a sh:NodeShape ;
    sh:targetClass :TransportNetworkThing ;
    sh:and ( its-location:FeatureShape ) .

:TransportNetworkShape
    a sh:NodeShape ;
    sh:targetClass :TransportNetwork ;
    sh:and ( its-location:LocationGroupShape ) .

:NetworkElementShape
    a sh:NodeShape ;
    sh:targetClass :NetworkElement ;
    sh:and ( its-location:FeatureShape ) .

:TransportNodeShape
    a sh:NodeShape ;
    sh:targetClass :TransportNode ;
    sh:and ( its-location:PointFeatureShape ) .

:JunctionShape
    a sh:NodeShape ;
    sh:targetClass :Junction ;
    sh:and ( its-location:PointFeatureShape ) .

:TravelledWayShape
    a sh:NodeShape ;
    sh:targetClass :TravelledWay ;
    sh:and ( its-location:LinearFeatureShape ) .

:TravelledWayLaneShape
    a sh:NodeShape ;
    sh:targetClass :TravelledWayLane ;
    sh:and ( its-location:LinearFeatureShape ) .

:TravelledWayLinkShape
    a sh:NodeShape ;
    sh:targetClass :TravelledWayLink ;
    sh:and ( its-location:LinearFeatureShape ) .

:TravelledWaySectionShape
    a sh:NodeShape ;
    sh:targetClass :TravelledWaySection ;
    sh:and ( its-location:LinearFeatureShape ) .

:TravelledWaySegmentShape
    a sh:NodeShape ;
    sh:targetClass :TravelledWaySegment ;
    sh:and ( its-location:LinearFeatureShape ) .

