// Diagram for RoadLinkUserType
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-core_Code" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-core:Code</TD></TR></TABLE>> URL="https://w3id.org/itsdata/core/v1/Code" margin=0]
		"its-location_LocationThing" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:LocationThing</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/LocationThing" margin=0]
	}
	RoadLinkUserType [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">RoadLinkUserType</TD></TR></TABLE>> URL="../RoadLinkUserType" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	RoadLinkUserType -> "its-core_Code" [arrowhead=onormal style=solid]
	RoadLinkUserType -> "its-location_LocationThing" [arrowhead=onormal style=solid]
}
