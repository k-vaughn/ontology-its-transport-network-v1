// Diagram for TransportAlert
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-location_Feature" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:Feature</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/Feature" margin=0]
		TransportAlertThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TransportAlertThing</TD></TR></TABLE>> URL="../TransportAlertThing" margin=0]
	}
	TransportAlert [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">TransportAlert</TD></TR></TABLE>> URL="../TransportAlert" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	TransportAlert -> "its-location_Feature" [arrowhead=onormal style=solid]
	TransportAlert -> TransportAlertThing [arrowhead=onormal style=solid]
}
