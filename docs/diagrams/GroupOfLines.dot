// Diagram for GroupOfLines
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		"its-location_LocationGroup" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-location:LocationGroup</TD></TR></TABLE>> URL="https://w3id.org/itsdata/location/v1/LocationGroup" margin=0]
		PublicTransportSystemThing [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PublicTransportSystemThing</TD></TR></TABLE>> URL="../PublicTransportSystemThing" margin=0]
	}
	GroupOfLines [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">GroupOfLines</TD></TR></TABLE>> URL="../GroupOfLines" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	GroupOfLines -> "its-location_LocationGroup" [arrowhead=onormal style=solid]
	GroupOfLines -> PublicTransportSystemThing [arrowhead=onormal style=solid]
}
